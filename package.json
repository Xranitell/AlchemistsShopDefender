{
  "name": "alchemists-shop-rune-defense",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc -b --noEmit",
    "lint": "tsc -b --noEmit",
    "test:viewport": "playwright test",
    "test:viewport:update": "playwright test --update-snapshots",
    "package": "npm run build && cd dist && zip -r ../alchemists-shop-rune-defense.zip ."
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "terser": "^5.47.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
